# Files excluded from the published pub.dev package.
#
# This file is authoritative for publishing and does not rely on git state, so
# it also lists the build/editor artifacts (normally handled by .gitignore) to
# keep the archive correct even when publishing from a fresh checkout.

# Build artifacts and caches (the test cache alone can be tens of MB).
build/
.dart_tool/
coverage/
doc/api/
**/doc/api/

# Editor / tooling metadata.
*.iml
.idea/
.vscode/
.metadata
.DS_Store
.flutter-plugins-dependencies

# Lockfile is not published for libraries.
pubspec.lock

# Reference copy of the upstream Shiki source (used only for porting).
shiki-main/

# Tests and fixtures: the fixture grammars/themes duplicate data already in
# lib/langs/ and lib/themes/, and consumers don't run the package's tests.
test/

# The Pierre themes' verbatim JSON originals duplicate the JSON already embedded
# in lib/pierre_themes/*.dart. Kept in git as reference; not shipped to pub.dev.
lib/pierre_themes/json/

playground/

# The showcase website is a full Flutter app (fonts, its own deps). It's
# committed in git as a showcase but must not ship inside the published package.
website/